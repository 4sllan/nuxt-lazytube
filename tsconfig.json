{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "types": ["node", "vue"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.js"]
}
